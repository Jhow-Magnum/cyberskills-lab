FROM debian:12-slim

LABEL maintainer="CTF SENAI" description="CenГЎrio Network Security - 3 Desafios"

# Instalar ferramentas de anГЎlise de rede
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-server nmap netcat-openbsd iproute2 iputils-ping file \
    && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# SSH config
RUN mkdir -p /var/run/sshd && echo 'root:root' | chpasswd \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config

# Criar usuГЎrio padrГЈo para terminal
RUN useradd -m -s /bin/bash user && echo 'user:user' | chpasswd

# Criar desafios dinГўmicos
RUN mkdir -p /opt/network \
    && printf '#!/bin/bash\necho "Desafio 1: Descubra o IP do container"\necho "Use: ip addr, hostname -I ou ifconfig"\necho ""\necho "Sua resposta (IP):"\nread answer\nmy_ip=$(hostname -I | awk '\''{print $1}'\'' | tr -d '\'' \n'\'' | tr -d '\''\r'\'' | xargs)\nif [ "$answer" = "$my_ip" ]; then\n  echo "Correto! Flag: N3TW0RK_1P"\nelse\n  echo "Incorreto. Tente novamente."\nfi\n' > /opt/network/challenge1.sh && chmod +x /opt/network/challenge1.sh \
    && printf '#!/bin/bash\necho "Desafio 2: Conte portas TCP em LISTEN"\necho "Use: netstat -tuln | grep LISTEN | wc -l"\necho ""\necho "Sua resposta (nГєmero):"\nread answer\nports=$(netstat -tuln 2>/dev/null | grep LISTEN | wc -l)\nif [ "$answer" = "$ports" ]; then\n  echo "Correto! Flag: P0RT_C0UNT"\nelse\n  echo "Incorreto. Resposta: $ports"\nfi\n' > /opt/network/challenge2.sh && chmod +x /opt/network/challenge2.sh \
    && printf '#!/bin/bash\necho "Desafio 3: Porta do SSH"\necho "Use: netstat -tuln | grep ssh ou ss -tuln"\necho ""\necho "Sua resposta (porta):"\nread answer\nif [ "$answer" = "22" ]; then\n  echo "Correto! Flag: SSH_P0RT_22"\nelse\n  echo "Incorreto. Verifique com: netstat -tuln | grep :22"\nfi\n' > /opt/network/challenge3.sh && chmod +x /opt/network/challenge3.sh

# ServiГ§os fake
RUN printf '#!/bin/bash\nnc -l -p 8080 &\nnc -l -p 9000 &\nnc -l -p 9001 &\n' > /start-services.sh && chmod +x /start-services.sh

# Criar README educativo estilo Bandit
RUN printf '=== CYBERSKILLS LAB - NETWORK ANALYSIS ===\n\nBem-vindo aos desafios de AnГЎlise de Rede!\nVocГЄ estГЎ logado como '\''user'\''. Explore a rede.\n\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n\n3 DESAFIOS DE ANГЃLISE DE REDE\n\nComandos Гєteis:\nвЂў /opt/network/challenge1.sh\nвЂў /opt/network/challenge2.sh\nвЂў /opt/network/challenge3.sh\nвЂў ip addr\nвЂў ip a\nвЂў hostname -I\nвЂў ifconfig\nвЂў netstat -tuln\nвЂў netstat -tuln | grep LISTEN\nвЂў ss -tuln\nвЂў ss -tuln | wc -l\nвЂў nmap localhost\nвЂў nmap -p- localhost\nвЂў ps aux\nвЂў ps aux | grep ssh\n\nDicas gerais:\n1. ServiГ§os de rede escutam em portas especГ­ficas\n2. SSH geralmente usa porta 22\n3. HTTP usa porta 80, HTTPS usa 443\n4. Portas LISTEN indicam serviГ§os ativos\n5. Containers tГЄm IPs internos\n6. Contar linhas ajuda a quantificar resultados\n\nRecursos:\nвЂў Comandos de rede: ip, netstat, ss, nmap\nвЂў Processos: ps, grep\nвЂў Arquivos: /root/network\n\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n\nUsando Google/IA:\n\nPergunte: "Como ver portas abertas no Linux?"\nPergunte: "DiferenГ§a entre netstat e ss?"\nPergunte: "Como descobrir IP do container?"\n\nNГЈo peГ§a soluГ§Гµes diretas!\n\nAPRENDA networking, nГЈo apenas resolva!\n\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n\nLembre-se: A melhor forma de aprender Г© tentando sozinho primeiro!\nUse as dicas apenas se estiver realmente travado.\n\nBoa sorte, hacker!\n' > /home/user/README \
    && chown user:user /home/user/README \
    && echo '' >> /home/user/.bashrc \
    && echo '[ -f ~/README ] && cat ~/README' >> /home/user/.bashrc \
    && echo '' >> /home/user/.bashrc

# Script de inicializaГ§ГЈo
RUN printf '#!/bin/bash\n/start-services.sh\n/usr/sbin/sshd -D\n' > /usr/local/bin/start.sh && chmod +x /usr/local/bin/start.sh

# Limpar historico de comandos
RUN rm -f /root/.bash_history /home/user/.bash_history 2>/dev/null || true

WORKDIR /home/user
EXPOSE 22
CMD ["/usr/local/bin/start.sh"]
