FROM debian:12-slim

LABEL maintainer="CyberSkills Lab" description="CenГЎrio Network Security - 3 Desafios"

# Instalar apenas ferramentas essenciais
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-server nmap netcat-openbsd iproute2 iputils-ping file \
    && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# SSH config
RUN mkdir -p /var/run/sshd && echo 'root:root' | chpasswd \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config

# Criar desafios
RUN mkdir -p /root/network \
    && echo "172.18.0.2" > /root/network/ip_flag.txt \
    && echo "5" > /root/network/ports_flag.txt \
    && echo "22" > /root/network/ssh_port_flag.txt

# ServiГ§os fake
RUN printf '#!/bin/bash\nnc -l -p 8080 &\nnc -l -p 9000 &\nnc -l -p 9001 &\n' > /start-services.sh && chmod +x /start-services.sh

# Criar README educativo
RUN printf '=== CYBERSKILLS LAB - NETWORK ANALYSIS ===\n\nBem-vindo aos desafios de AnГЎlise de Rede!\nVocГӘ estГЎ logado como '\''user'\'' Explore a rede.\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n3 DESAFIOS DE ANГҒLISE DE REDE\n\nObjetivo: Identificar serviГ§os, portas e configuraГ§Гөes de rede.\n\nComandos essenciais:\nвҖў ip addr                  - Mostra endereГ§os IP\nвҖў hostname -I              - IP do host\nвҖў netstat -tuln            - Portas abertas (TCP/UDP)\nвҖў ss -tuln                 - Alternativa ao netstat\nвҖў nmap localhost           - Scan de portas\nвҖў ps aux                   - Processos rodando\n\nDicas gerais:\n1. ServiГ§os de rede escutam em portas especГӯficas\n2. SSH geralmente usa porta 22\n3. HTTP usa porta 80, HTTPS usa 443\n4. Portas LISTEN indicam serviГ§os ativos\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\nрҹ’Ў Usando Google/IA:\n\nвң… Pergunte: "Como ver portas abertas no Linux?"\nвң… Pergunte: "DiferenГ§a entre netstat e ss?"\nвң… Pergunte: "Como descobrir IP do container?"\n\nвқҢ NГЈo peГ§a soluГ§Гөes diretas!\n\nAPRENDA networking, nГЈo apenas resolva!\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\nComece explorando! Digite: ip addr\n' > /home/user/README.txt \
    && chown user:user /home/user/README.txt

# Script de inicializaГ§ГЈo
RUN printf '#!/bin/bash\n/start-services.sh\n/usr/sbin/sshd -D\n' > /start.sh && chmod +x /start.sh

EXPOSE 22
CMD ["/start.sh"]
