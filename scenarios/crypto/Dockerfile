FROM debian:12-slim

LABEL maintainer="CyberSkills Lab" description="CenГЎrio Criptografia - 8 Desafios"

# Instalar apenas ferramentas essenciais
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-server python3 openssl bc xxd zip unzip file coreutils binutils \
    && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# SSH config
RUN mkdir -p /var/run/sshd && echo 'root:root' | chpasswd \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config

# Criar todos os desafios em uma camada
RUN mkdir -p /opt/challenges/crypto /var/log/ctf /tmp/backup /etc/ctf /home/ctfuser/.secrets /srv/archives \
    && echo "R09SRF9NYXN0ZXJfMjAyNQ==" > /opt/challenges/crypto/message.txt \
    && echo "PVCURE_FVZCYR" > /var/log/ctf/encrypted.log \
    && printf "x0r_s1mpl3" | python3 -c "import sys; data=sys.stdin.buffer.read(); sys.stdout.buffer.write(bytes([b^0x42 for b in data]))" > /tmp/backup/data.enc \
    && echo "482c811da5d5b4bc6d497ffa98491e38" > /etc/ctf/shadow.hash \
    && echo -e "password\npassword123\nadmin\nroot\n123456\nqwerty\nletmein\nwelcome" > /usr/share/dict/common.txt \
    && echo "j43z4y_jy4jr3k" > /home/ctfuser/.secrets/note.txt \
    && mkdir -p /tmp/ziptemp && echo "z1p_r3p41r3d" > /tmp/ziptemp/flag.txt \
    && cd /tmp/ziptemp && zip -q /srv/archives/backup.zip flag.txt \
    && printf '\x00\x00' | dd of=/srv/archives/backup.zip bs=1 count=2 conv=notrunc 2>/dev/null \
    && rm -rf /tmp/ziptemp

# Criar README educativo estilo Bandit
RUN printf '=== CYBERSKILLS LAB - CRIPTOGRAFIA ===\n\nBem-vindo aos desafios de Criptografia!\nVocГӘ estГЎ logado como '\''root'\''. Explore e decifre.\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n8 DESAFIOS DE CRIPTOGRAFIA\n\nComandos Гәteis:\nвҖў base64 -d\nвҖў echo -n "texto" | md5sum\nвҖў echo -n "texto" | sha256sum\nвҖў sha256sum | cut -c1-8\nвҖў tr '\''A-Za-z'\'' '\''N-ZA-Mn-za-m'\''\nвҖў tr '\''A-Za-z'\'' '\''H-ZA-Gh-za-g'\''\nвҖў xxd arquivo\nвҖў xxd -r arquivo\nвҖў python3 -c "cГіdigo"\nвҖў for i in {0..255}; do ... done\nвҖў while read palavra; do ... done < wordlist\nвҖў openssl enc -d\nвҖў file arquivo\nвҖў unzip arquivo.zip\nвҖў printf '\''\\x50\\x4B'\'' | dd of=arquivo\n\nDicas gerais:\n1. Arquivos codificados estГЈo espalhados pelo sistema\n2. Hashes podem ser quebrados com wordlists\n3. ROT13 Г© uma cifra de substituiГ§ГЈo simples\n4. Caesar cipher usa rotaГ§ГЈo de letras\n5. XOR pode ser quebrado testando todas as chaves (0-255)\n6. Magic numbers identificam tipos de arquivo\n7. ZIP comeГ§a com bytes 50 4B 03 04\n\nRecursos:\nвҖў DiretГіrios: /opt, /var/log, /tmp, /etc, /home, /srv\nвҖў Wordlists: /usr/share/dict\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\nрҹ’Ў Usando Google/IA:\n\nвң… Pergunte: "Como decodificar Base64 no Linux?"\nвң… Pergunte: "O que Г© ROT13 e como decifrar?"\nвң… Pergunte: "Como quebrar hash MD5 com wordlist?"\n\nвқҢ NГЈo peГ§a soluГ§Гөes prontas!\n\nAPRENDA criptografia, nГЈo apenas resolva!\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\nLembre-se: A melhor forma de aprender Г© tentando sozinho primeiro!\nUse as dicas apenas se estiver realmente travado.\n\nBoa sorte, hacker!\n' > /root/README.txt

EXPOSE 22
CMD ["/usr/sbin/sshd", "-D"]
