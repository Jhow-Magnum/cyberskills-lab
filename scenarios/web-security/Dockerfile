FROM debian:12-slim

LABEL maintainer="CyberSkills Lab" description="CenГЎrio Web Security - 3 Desafios"

# Instalar apenas ferramentas essenciais
RUN apt-get update && apt-get install -y --no-install-recommends \
    apache2 php openssh-server curl wget netcat-openbsd file \
    && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# SSH config
RUN mkdir -p /var/run/sshd && echo 'root:root' | chpasswd \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config

# Criar usuГЎrio padrГЈo para terminal
RUN useradd -m -s /bin/bash user && echo 'user:user' | chpasswd

# Criar desafios web
RUN echo -e "User-agent: *\nDisallow: /admin/\nDisallow: /secret/\n\n# Flag: R0B0TS_TXT" > /var/www/html/robots.txt \
    && echo -e '<!DOCTYPE html>\n<html><head><meta charset="UTF-8"><title>CyberSkills Lab</title></head>\n<body><h1>рҹҺҜ CyberSkills Lab - Web Security</h1>\n<!-- Flag: HTML_C0MM3NT -->\n<p>Explore o site.</p></body></html>' > /var/www/html/index.html \
    && mkdir -p /var/www/html/login \
    && echo -e '<?php\nif(isset($_POST["username"]) && isset($_POST["password"])) {\n    echo "<h2>Flag: SQL_1NJ3CT10N</h2>";\n}\n?>\n<form method="POST">\n<input type="text" name="username" placeholder="Username">\n<input type="password" name="password" placeholder="Password">\n<button type="submit">Login</button>\n</form>' > /var/www/html/login/index.php

# Criar README educativo
RUN printf '=== CYBERSKILLS LAB - WEB SECURITY ===\n\nBem-vindo aos desafios de SeguranГ§a Web!\nVocГӘ estГЎ logado como '\''user'\'' Explore o servidor web.\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n3 DESAFIOS DE SEGURANГҮA WEB\n\nObjetivo: Explorar vulnerabilidades comuns em aplicaГ§Гөes web.\n\nComandos essenciais:\nвҖў curl http://localhost     - Faz requisiГ§Гөes HTTP\nвҖў wget http://localhost     - Baixa pГЎginas web\nвҖў cat /var/www/html/*       - LГӘ arquivos do servidor\nвҖў find /var/www -type f     - Busca arquivos web\nвҖў grep -r "texto" /var/www - Procura em arquivos\n\nDicas gerais:\n1. Servidores web guardam arquivos em /var/www/html\n2. Arquivos especiais: robots.txt, .htaccess, index.html\n3. ComentГЎrios HTML podem conter informaГ§Гөes sensГӯveis\n4. SQL Injection explora queries mal construГӯdas\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\nрҹ’Ў Usando Google/IA:\n\nвң… Pergunte: "O que Г© robots.txt e para que serve?"\nвң… Pergunte: "Como ver cГіdigo fonte HTML no terminal?"\nвң… Pergunte: "O que Г© SQL Injection bГЎsico?"\n\nвқҢ NГЈo peГ§a: "Me dГӘ as flags do desafio web"\n\nAPRENDA seguranГ§a web, nГЈo apenas copie!\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\nComece explorando! Digite: curl http://localhost\n' > /home/user/README.txt \
    && chown user:user /home/user/README.txt

# Script de inicializaГ§ГЈo
RUN printf '#!/bin/bash\nservice apache2 start\n/usr/sbin/sshd -D\n' > /start.sh && chmod +x /start.sh

EXPOSE 22 80
CMD ["/start.sh"]
