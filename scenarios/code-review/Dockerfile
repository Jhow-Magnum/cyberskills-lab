FROM debian:12-slim

LABEL maintainer="CTF SENAI" description="CenГЎrio Code Review - 6 Desafios"

# Instalar apenas ferramentas essenciais
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-server python3 php file \
    && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# SSH config
RUN mkdir -p /var/run/sshd && echo 'root:root' | chpasswd \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config

# Criar todos os desafios
RUN mkdir -p /opt/vulnerable \
    && printf '#!/usr/bin/env python3\nimport os\nuser_input = input("Digite um comando: ")\n# VULNERГЃVEL: Command Injection!\n# Flag: CMD_1NJ3CT10N\nos.system(user_input)\n' > /opt/vulnerable/vuln1.py \
    && printf 'const mysql = require("mysql");\nconst username = req.body.username;\n// VULNERГЃVEL: SQL Injection!\n// Flag: SQL_1NJ3CT10N\nconst query = "SELECT * FROM users WHERE username = '\''"+username+"'\''";\n' > /opt/vulnerable/vuln2.js \
    && printf '#!/usr/bin/env python3\n# VULNERГЃVEL: Senha hardcoded!\n# Flag: H4RDC0D3D_P4SS\nDB_PASSWORD = "super_secret_password_123"\n' > /opt/vulnerable/config.py \
    && printf '<?php\n$code = $_GET["code"];\n// VULNERГЃVEL: Code Execution!\n// Flag: C0D3_3X3C\neval($code);\n?>\n' > /opt/vulnerable/vuln4.php \
    && printf '#!/usr/bin/env python3\n# VULNERГЃVEL: API Key exposta!\n# Flag: L34K3D_K3Y\nAPI_KEY = "sk-1234567890abcdef"\nSECRET_TOKEN = "ghp_xxxxxxxxxxxxxxxxxxxx"\n' > /opt/vulnerable/.env \
    && printf 'const userInput = req.query.name;\n// VULNERГЃVEL: XSS!\n// Flag: XSS_VULN\ndocument.getElementById("output").innerHTML = userInput;\n' > /opt/vulnerable/vuln6.js

# Criar README educativo estilo Bandit
RUN printf '=== CYBERSKILLS LAB - CODE REVIEW ===\n\nBem-vindo aos desafios de RevisГЈo de CГіdigo!\nVocГЄ estГЎ logado como '\''root'\''. Analise cГіdigos vulnerГЎveis.\n\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n\n6 DESAFIOS DE REVISГѓO DE CГ“DIGO\n\nComandos Гєteis:\nвЂў ls /opt/vulnerable\nвЂў cat /opt/vulnerable/*.py\nвЂў cat /opt/vulnerable/*.js\nвЂў cat /opt/vulnerable/*.php\nвЂў cat /opt/vulnerable/.env\nвЂў grep -r "Flag" /opt\nвЂў grep -r "VULNERГЃVEL" /opt\nвЂў grep -r "password" /opt\nвЂў grep -r "eval" /opt\nвЂў grep -r "system" /opt\nвЂў find /opt -name "*.py"\nвЂў find /opt -name ".env"\n\nDicas gerais:\n1. ComentГЎrios indicam vulnerabilidades\n2. FunГ§Гµes perigosas: eval(), exec(), system()\n3. Credenciais hardcoded sГЈo inseguras\n4. Queries SQL sem sanitizaГ§ГЈo sГЈo vulnerГЎveis\n5. Input do usuГЎrio deve ser validado\n6. API keys nГЈo devem estar no cГіdigo\n7. XSS explora saГ­da nГЈo sanitizada\n\nVulnerabilidades comuns:\nвЂў Command Injection\nвЂў SQL Injection\nвЂў Hardcoded Credentials\nвЂў Code Execution\nвЂў API Key Leak\nвЂў Cross-Site Scripting (XSS)\n\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n\nUsando Google/IA:\n\nPergunte: "O que Г© Command Injection?"\nPergunte: "Por que eval() Г© perigoso?"\nPergunte: "Como prevenir SQL Injection?"\n\nNГЈo peГ§a: "Encontre as vulnerabilidades para mim"\n\nAPRENDA seguranГ§a de cГіdigo, nГЈo apenas identifique!\n\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n\nLembre-se: A melhor forma de aprender Г© tentando sozinho primeiro!\nUse as dicas apenas se estiver realmente travado.\n\nBoa sorte, hacker!\n' > /root/README

# Auto-exibir README ao logar
RUN echo '' >> /root/.bashrc && \
    echo '[ -f /root/README ] && cat /root/README' >> /root/.bashrc && \
    echo '' >> /root/.bashrc

# Limpar historico de comandos
RUN rm -f /root/.bash_history /home/user/.bash_history 2>/dev/null || true

WORKDIR /root
EXPOSE 22
CMD ["/usr/sbin/sshd", "-D"]
