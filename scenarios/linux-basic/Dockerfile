FROM debian:12-slim

LABEL maintainer="CyberSkills Lab" description="CenГЎrio Linux BГЎsico - 14 Desafios"

# Instalar ferramentas minimalistas
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-server bash coreutils grep sed gawk findutils less vim procps sudo cron file \
    && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# SSH config
RUN mkdir -p /var/run/sshd && echo 'root:root' | chpasswd \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config

# Criar todos os desafios em uma camada
RUN mkdir -p /root/SENAI /root/scripts/1 /root/.hidden /root/linux /etc/cron.d \
    && echo "pa\$t4" > /root/SENAI/flag \
    && echo -e '#!/bin/bash\necho "==================================="\necho "  Script executado com sucesso!"\necho "==================================="\necho ""\necho "CГіdigo encontrado: cOdi6o"\necho ""' > /root/scripts/1/script.sh && chmod +x /root/scripts/1/script.sh \
    && echo "echo 'Flag do histГіrico: h1st0ry_m4tt3rs'" >> /root/.bash_history \
    && echo "H1DD3N_F1L3" > /root/.hidden/.secret_flag \
    && echo "SU1D_B1N4RY" > /root/linux/suid_flag.txt && chmod 4755 /usr/bin/find \
    && echo -e "# CTF Cron Job\n# Flag: cr0n_m4st3r\n*/5 * * * * root echo 'Cron executado' >> /tmp/cron.log" > /etc/cron.d/ctf-cron && chmod 644 /etc/cron.d/ctf-cron

# Criar README educativo estilo Bandit
RUN printf '=== CYBERSKILLS LAB - LINUX BГҒSICO ===\n\nBem-vindo aos desafios de Linux!\nVocГӘ estГЎ logado como '\''root'\''. Explore o sistema de arquivos.\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n14 DESAFIOS DE COMANDOS LINUX\n\nComandos Гәteis:\nвҖў whoami\nвҖў ls, ls -la, ls -R\nвҖў cd <diretorio>\nвҖў cat <arquivo>\nвҖў find / -name <arquivo>\nвҖў find / -type f -perm -4000\nвҖў grep <texto> <arquivo>\nвҖў grep -r "texto" /root\nвҖў history\nвҖў cat ~/.bash_history\nвҖў ps aux\nвҖў ps -ef\nвҖў chmod +x script.sh\nвҖў ./script.sh\nвҖў cat /etc/cron.d/*\nвҖў crontab -l\n\nDicas gerais:\n1. Arquivos ocultos comeГ§am com ponto (.)\n2. Use TAB para autocompletar comandos\n3. Explore diretГіrios: /root, /home, /etc, /tmp\n4. Scripts executГЎveis tГӘm permissГЈo +x\n5. HistГіrico de comandos guarda aГ§Гөes anteriores\n6. Processos tГӘm PIDs Гәnicos\n7. SUID permite executar como outro usuГЎrio\n8. Cron jobs sГЈo tarefas agendadas\n\nRecursos:\nвҖў DiretГіrios importantes: /root, /etc, /tmp, /var\nвҖў Arquivos de configuraГ§ГЈo: /etc/cron.d\nвҖў Scripts: /root/scripts\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\nрҹ’Ў Usando Google/IA:\n\nвң… Pergunte: "Como listar arquivos ocultos no Linux?"\nвң… Pergunte: "O que faz o comando find?"\nвң… Pergunte: "Como buscar texto dentro de arquivos?"\n\nвқҢ NГЈo peГ§a: "Me dГӘ a resposta do desafio X"\n\nAPRENDA os comandos, nГЈo apenas copie!\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\nLembre-se: A melhor forma de aprender Г© tentando sozinho primeiro!\nUse as dicas apenas se estiver realmente travado.\n\nBoa sorte, hacker!\n' > /root/README.txt

EXPOSE 22
CMD ["/usr/sbin/sshd", "-D"]
